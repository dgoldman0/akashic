    "accepted_decisions": [
      {
        "id": "library-corpus-scope",
        "decision": "Library owns one machine-level corpus; Practice stores stable bindings and authority, never Library bytes."
      },
      {
        "id": "library-record-kinds",
        "decision": "The initial Library has mutable managed documents with immutable content revisions and immutable captures."
      },
      {
        "id": "library-admitted-content",
        "decision": "The initial closed content scope is valid UTF-8 plain text, Markdown, CSV capture, and qualified safe observation-text projections."
      },
      {
        "id": "library-retention",
        "decision": "A managed document retains its current content revision and the three immediately preceding revisions."
      },
      {
        "id": "library-archive-tombstone",
        "decision": "Archive preserves content and exact resolution; destructive deletion leaves a minimal non-content tombstone and never reuses the RID."
      },
      {
        "id": "projection-owner-lifecycle",
        "decision": "Only bounded active/open records receive one-RID projection owners; every acquire retains through the owner root and returns an activation-local acquisition token."
      },
      {
        "id": "qualified-locators",
        "decision": "Persistent locators carry stable owner/domain identity, semantic RREF facts, exact domain revision and available digest/projection facts; exact failure never advances to latest."
      },
      {
        "id": "live-binding-boundary",
        "decision": "LBINDs, component instance/generation, acquisition tokens, live capabilities, and callbacks are activation-local and are never persisted or treated as authority."
      },
      {
        "id": "handler-negotiation",
        "decision": "Handler matching is typed by owner, kind, and media; selection is deterministic and a real Open With ambiguity is surfaced instead of priority-only dispatch."
      },
      {
        "id": "desk-service-table",
        "decision": "The initial bounded service table remains Desk-private until a second host proves that it is a general interop mechanism."
      }
    ]
  },
